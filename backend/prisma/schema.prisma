generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String
  createdAt     DateTime      @default(now())
  timeBlocks    TimeBlock[]
  ideas         Idea[]
  streak        UserStreak?
  weeklyReviews WeeklyReview[]
}

model Idea {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  problem     String
  type        String        @default("Work")
  subType     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lastVisited DateTime?
  decayScore  Float         @default(1.0)
  priority    Int           @default(0)
  archived    Boolean       @default(false)
  sections    IdeaSection[]
  tags        IdeaTag[]
  sourceLinks IdeaLink[]    @relation("source")
  targetLinks IdeaLink[]    @relation("target")
  revisions   IdeaRevision[]
}

model IdeaSection {
  id          String @id @default(uuid())
  ideaId      String
  idea        Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  sectionName String
  content     String
  orderIndex  Int
}

model IdeaTag {
  id     String @id @default(uuid())
  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  name   String

  @@unique([ideaId, name])
}

model IdeaLink {
  id        String   @id @default(uuid())
  sourceId  String
  targetId  String
  source    Idea     @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Idea     @relation("target", fields: [targetId], references: [id], onDelete: Cascade)
  linkType  String
  reason    String?
  createdAt DateTime @default(now())
}

model IdeaRevision {
  id        String   @id @default(uuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  snapshot  String
  editNote  String?
  createdAt DateTime @default(now())
}

model TimeBlock {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  day          String
  startTime    String
  endTime      String
  reminderTime Int
  status       String     @default("SCHEDULED")
  logs         BlockLog[]
}

model BlockLog {
  id          String    @id @default(uuid())
  blockId     String
  block       TimeBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  output      String
  completedAt DateTime  @default(now())
}

model LearningTopic {
  id              String @id @default(uuid())
  topic           String
  kidExplanation  String
  examAnswer      String
  bulletNotes     String
  stepExplanation String
}

model UserStreak {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActiveDate   DateTime?
  totalActiveDays  Int       @default(0)
  freezesAvailable Int       @default(2)
  freezesUsed      Int       @default(0)
}

model WeeklyReview {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart       DateTime
  blocksTotal     Int
  blocksCompleted Int
  ideasCreated    Int
  ideasDecayed    Int       @default(0)
  moodRating      Int?
  aiInsights      String?
  decisions       String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
}
