# Backend Configuration

# Get a free PostgreSQL database from https://supabase.com
# Example format: postgresql://postgres.xxxxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=""

# JWT Secret for authentication (Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate a secure one)
JWT_SECRET="your_secure_random_string_here"

# Google Gemini API Key (Get from Google AI Studio)
GEMINI_API_KEY="AIzaSy...your_key_here..."
